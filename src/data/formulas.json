      {
        "name":"Weighted Average",
        "tag":"Important",
        "formula":"Weighted Avg = (n1×A1 + n2×A2) ÷ (n1+n2)",
        "vars":[
          {"k":"n1,n2","d":"Number of items in each group"},
          {"k":"A1,A2","d":"Average of each group"}
        ],
        "examples":[
          {
            "q":"Class A: 30 students avg 70. Class B: 20 students avg 80. Combined avg?",
